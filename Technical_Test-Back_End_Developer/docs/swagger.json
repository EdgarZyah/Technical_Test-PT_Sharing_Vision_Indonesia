{
    "swagger": "2.0",
    "info": {
        "description": "REST API untuk aplikasi HaloEmas - platform digital investasi dan transaksi emas.\nHarga emas diambil dari https://hargaemas.logikarya.com (Antam).",
        "title": "HaloEmas API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/api/balance": {
            "get": {
                "description": "Menampilkan saldo emas user dalam gram dan nilai Rupiah berdasarkan harga jual terkini",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Balance"
                ],
                "summary": "Get gold balance",
                "parameters": [
                    {
                        "type": "string",
                        "description": "User ID",
                        "name": "X-User-ID",
                        "in": "header",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/handler.BalanceResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/handler.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/buy": {
            "post": {
                "description": "Membeli emas berdasarkan nominal Rupiah menggunakan harga beli Antam terkini",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Gold"
                ],
                "summary": "Buy gold",
                "parameters": [
                    {
                        "type": "string",
                        "description": "User ID",
                        "name": "X-User-ID",
                        "in": "header",
                        "required": true
                    },
                    {
                        "description": "Jumlah pembelian dalam Rupiah",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/handler.BuyRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/handler.BuyResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/handler.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/price": {
            "get": {
                "description": "Mengembalikan harga emas Antam terkini (buy/sell) dari API hargaemas.logikarya.com",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Gold"
                ],
                "summary": "Get gold price",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/handler.PriceResponse"
                        }
                    },
                    "503": {
                        "description": "Service Unavailable",
                        "schema": {
                            "$ref": "#/definitions/handler.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/profile": {
            "get": {
                "description": "Menampilkan profil user termasuk saldo emas",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "User"
                ],
                "summary": "Get user profile",
                "parameters": [
                    {
                        "type": "string",
                        "description": "User ID",
                        "name": "X-User-ID",
                        "in": "header",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/handler.ProfileResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/handler.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/handler.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/register": {
            "post": {
                "description": "Mendaftarkan user baru",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "User"
                ],
                "summary": "Register new user",
                "parameters": [
                    {
                        "description": "Data user baru",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/handler.RegisterRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/handler.RegisterResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/handler.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/sell": {
            "post": {
                "description": "Menjual emas berdasarkan berat gram menggunakan harga jual (buyback) Antam terkini",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Gold"
                ],
                "summary": "Sell gold",
                "parameters": [
                    {
                        "type": "string",
                        "description": "User ID",
                        "name": "X-User-ID",
                        "in": "header",
                        "required": true
                    },
                    {
                        "description": "Jumlah emas yang dijual dalam gram",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/handler.SellRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/handler.SellResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/handler.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/transactions": {
            "get": {
                "description": "Menampilkan daftar riwayat transaksi user",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Transactions"
                ],
                "summary": "Get transactions",
                "parameters": [
                    {
                        "type": "string",
                        "description": "User ID",
                        "name": "X-User-ID",
                        "in": "header",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/handler.Transaction"
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/handler.ErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "handler.BalanceResponse": {
            "type": "object",
            "properties": {
                "amount": {
                    "type": "integer",
                    "example": 1110000
                },
                "gram": {
                    "type": "number",
                    "example": 0.571
                }
            }
        },
        "handler.BuyRequest": {
            "type": "object",
            "properties": {
                "amount": {
                    "type": "integer",
                    "example": 500000
                }
            }
        },
        "handler.BuyResponse": {
            "type": "object",
            "properties": {
                "gram": {
                    "type": "number",
                    "example": 0.257
                },
                "price": {
                    "type": "integer",
                    "example": 1945200
                }
            }
        },
        "handler.ErrorResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string",
                    "example": "Amount harus lebih dari 0"
                }
            }
        },
        "handler.PriceResponse": {
            "type": "object",
            "properties": {
                "buy": {
                    "type": "integer",
                    "example": 1945200
                },
                "date": {
                    "type": "string",
                    "example": "2026-07-16"
                },
                "sell": {
                    "type": "integer",
                    "example": 1925000
                }
            }
        },
        "handler.ProfileResponse": {
            "type": "object",
            "properties": {
                "amount": {
                    "type": "integer",
                    "example": 1110000
                },
                "email": {
                    "type": "string",
                    "example": "budi@example.com"
                },
                "gram": {
                    "type": "number",
                    "example": 0.571
                },
                "id": {
                    "type": "integer",
                    "example": 1
                },
                "nama": {
                    "type": "string",
                    "example": "Budi Hartono"
                }
            }
        },
        "handler.RegisterRequest": {
            "type": "object",
            "properties": {
                "email": {
                    "type": "string",
                    "example": "budi@example.com"
                },
                "nama": {
                    "type": "string",
                    "example": "Budi Hartono"
                }
            }
        },
        "handler.RegisterResponse": {
            "type": "object",
            "properties": {
                "email": {
                    "type": "string",
                    "example": "budi@example.com"
                },
                "id": {
                    "type": "integer",
                    "example": 1
                },
                "message": {
                    "type": "string",
                    "example": "Registrasi berhasil"
                },
                "nama": {
                    "type": "string",
                    "example": "Budi Hartono"
                }
            }
        },
        "handler.SellRequest": {
            "type": "object",
            "properties": {
                "gram": {
                    "type": "number",
                    "example": 1
                }
            }
        },
        "handler.SellResponse": {
            "type": "object",
            "properties": {
                "amount": {
                    "type": "integer",
                    "example": 1925000
                }
            }
        },
        "handler.Transaction": {
            "type": "object",
            "properties": {
                "amount": {
                    "type": "integer",
                    "example": 500000
                },
                "created_at": {
                    "type": "string",
                    "example": "2026-07-10T10:00:00Z"
                },
                "gram": {
                    "type": "number",
                    "example": 0.257
                },
                "id": {
                    "type": "integer",
                    "example": 1
                },
                "type": {
                    "type": "string",
                    "example": "BUY"
                },
                "user_id": {
                    "type": "integer",
                    "example": 1
                }
            }
        }
    }
}